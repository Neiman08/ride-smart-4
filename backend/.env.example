# ═══════════════════════════════════════════════════════════
# Ride Smart 4.0 — Environment Variables
# Copy to .env and fill in your keys
# ═══════════════════════════════════════════════════════════

# ── BACKEND ────────────────────────────────────────────────
PORT=3000

# ── FLIGHTS (choose ONE — or add both for redundancy) ──────

# Option A: AviationStack — FREE 100 req/month
# https://aviationstack.com → Sign up → copy API Access Key
AVIATIONSTACK_KEY=

# Option B: AeroDataBox via RapidAPI — ~$10/month for 1000 req
# https://rapidapi.com/aedbx-aedbx/api/aerodatabox → Subscribe Basic
RAPIDAPI_KEY=

# Option C: OpenSky — FREE, no key needed, real ADSB data
# (automatically used if neither above key is set)

# ── EVENTS ─────────────────────────────────────────────────

# Option A: Ticketmaster — FREE 5000 req/day ✅ RECOMMENDED
# https://developer.ticketmaster.com → Create App → copy Consumer Key
TICKETMASTER_KEY=

# Option B: SeatGeek — FREE, has real capacity data
# https://seatgeek.com/account/develop → Create App → copy Client ID
SEATGEEK_CLIENT_ID=

# ── ZONES & MAPS ───────────────────────────────────────────

# Google Maps — $200 free credit/month (enough for ~20k zone lookups)
# Enable: Geocoding API, Places API, Distance Matrix API
# https://console.cloud.google.com → APIs & Services → Enable
GOOGLE_MAPS_API_KEY=

# ── WEATHER ────────────────────────────────────────────────

# OpenWeather — FREE 1000 req/day ✅ EASY WIN
# https://openweathermap.org/api → Sign up → copy API key
OPENWEATHER_API_KEY=

# ── EV STATIONS ────────────────────────────────────────────

# NREL — FREE, use DEMO_KEY for testing
# https://developer.nrel.gov/signup for production key
NREL_API_KEY=DEMO_KEY

# ═══════════════════════════════════════════════════════════
# QUICK START — add these 2 to get 80% of the value:
#   TICKETMASTER_KEY   (free, events)
#   OPENWEATHER_API_KEY (free, weather surge)
# ═══════════════════════════════════════════════════════════
